#!/usr/bin/env bash

set -eo pipefail

device=
imagefile=

usage() { printf "Use like:\n\t %s [device] [imagefile]\n\t %s -d [device] -i [imagefile]\n" "$0" "$0" 1>&2; exit 1; }
while getopts "d:i:h" o; do
	case "${o}" in
		d)
			device=${OPTARG}
			;;
		i)
			imagefile=${OPTARG}
			;;
		h|*)
			usage
			;;
	esac
done
shift $((OPTIND-1))

if [[ -z "$device" ]]; then
	device=$1
	shift
fi

if [[ -z "$imagefile" ]]; then
	imagefile=$1
	shift
fi

if [[ -z "$device" || -z "$imagefile" ]]; then
	usage
fi

if [[ ! -f "$imagefile" ]]; then
	echo "Image file '$imagefile' does not exist"
	exit 2
fi

device_info=$(udevadm info --query=property --path="/sys/block/${device##*/}")
device_bus=$(echo "$device_info" | perl -ne 'print "$1" if /^ID_BUS=(.*)/')
device_size_suffixed=$(lsblk -o SIZE "$device" | head -2 | tail -1)
device_size=$(echo "$device_size_suffixed" | perl -ne 'print $1 if /\s*([\d\.]+)G/')
set -x
if [[ "$device_bus" != "usb" ]]; then
	echo "Device $device is not a usb device?"
	exit 2
elif [[ "$(echo "$device_size < 8" | bc)" -eq 1 ]]; then
	echo "Device $device seems to be too small? $device_size_suffixed"
	exit 2
elif mount | grep -qF "$device"; then
	echo "Device $device is mounted"
	exit 2
fi

sudo pv --sync --output "$device" "$imagefile"
