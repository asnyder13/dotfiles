#!/usr/bin/env -S ruby -w
# frozen_string_literal: true
# typed: false

path = ARGV[0]
fail 'specify filename to create' unless path
fail 'file already exists' if File.exist? path

File.open(path, "w") {
  it.puts <<~HERE
	#!/usr/bin/env bash

  HERE
}
File.chmod(0755, path)
system (ENV['EDITOR'] || 'vim'), path
